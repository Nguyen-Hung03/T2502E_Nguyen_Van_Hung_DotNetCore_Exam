@model RentalCreateViewModel

@{
    ViewData["Title"] = "Thuê sách";
}

<h1>Tạo phiếu thuê truyện</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label asp-for="CustomerName" class="form-label"></label>
                <input asp-for="CustomerName" class="form-control" list="customerList" />
                <datalist id="customerList">
                    @foreach (var name in Model.CustomerSuggestions)
                    {
                        <option value="@name"></option>
                    }
                </datalist>
                <span asp-validation-for="CustomerName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ComicBookTitle" class="form-label"></label>
                <input asp-for="ComicBookTitle" class="form-control" list="comicList" id="comicBookTitle" />
                <datalist id="comicList">
                    @foreach (var title in Model.ComicBookSuggestions)
                    {
                        <option value="@title"></option>
                    }
                </datalist>
                <span asp-validation-for="ComicBookTitle" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="RentalDate" class="form-label"></label>
                <input asp-for="RentalDate" class="form-control" type="date" />
                <span asp-validation-for="RentalDate" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ReturnDate" class="form-label"></label>
                <input asp-for="ReturnDate" class="form-control" type="date" />
                <span asp-validation-for="ReturnDate" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Quantity" class="form-label"></label>
                <input asp-for="Quantity" class="form-control" />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="PricePerDay" class="form-label"></label>
                <input asp-for="PricePerDay" class="form-control" id="pricePerDay" />
                <span asp-validation-for="PricePerDay" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <input type="submit" value="Tạo phiếu thuê" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Danh sách thuê</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        const comicBookTitleInput = document.getElementById('comicBookTitle');
        const pricePerDayInput = document.getElementById('pricePerDay');

        async function loadPricePerDay() {
            const title = comicBookTitleInput.value.trim();
            if (!title) {
                return;
            }

            const response = await fetch(`/Rentals/GetPricePerDay?title=${encodeURIComponent(title)}`);
            if (response.ok) {
                const data = await response.json();
                pricePerDayInput.value = data.pricePerDay;
            }
        }

        comicBookTitleInput.addEventListener('change', loadPricePerDay);
        comicBookTitleInput.addEventListener('blur', loadPricePerDay);
    </script>
}
