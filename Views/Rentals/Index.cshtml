@model IEnumerable<Rental>

@{
    ViewData["Title"] = "Thuê sách";
}

<h1>Danh sách phiếu thuê</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

<p>
    <a asp-action="Create" class="btn btn-primary">Tạo phiếu thuê mới</a>
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Khách hàng</th>
            <th>Ngày thuê</th>
            <th>Ngày trả</th>
            <th>Trạng thái</th>
            <th>Tên truyện</th>
            <th>Số lượng</th>
            <th>Giá / ngày</th>
        </tr>
    </thead>
    <tbody>
@foreach (var rental in Model)
{
    foreach (var detail in rental.RentalDetails)
    {
        <tr>
            <td>@rental.Customer?.FullName</td>
            <td>@rental.RentalDate.ToString("dd/MM/yyyy")</td>
            <td>@rental.ReturnDate.ToString("dd/MM/yyyy")</td>
            <td>@rental.Status</td>
            <td>@detail.ComicBook?.Title</td>
            <td>@detail.Quantity</td>
            <td>@detail.PricePerDay.ToString("N0") đ</td>
        </tr>
    }
}
    </tbody>
</table>
