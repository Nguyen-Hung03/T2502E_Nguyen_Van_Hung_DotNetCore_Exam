@model ComicBook
@{
    ViewData["Title"] = "Chi tiết truyện";
    ViewData["PageTitle"] = "Chi tiết truyện tranh";
    ViewData["PageSubtitle"] = Model.Title;
}

<partial name="_PageHeader" />

<div class="form-shell">
    <div class="form-card">
        <dl class="row mb-0">
            <dt class="col-sm-4 text-muted">Tên truyện</dt>
            <dd class="col-sm-8 fw-bold">@Model.Title</dd>
            <dt class="col-sm-4 text-muted">Tác giả</dt>
            <dd class="col-sm-8">@Model.Author</dd>
            <dt class="col-sm-4 text-muted">Giá thuê / ngày</dt>
            <dd class="col-sm-8"><span class="price-badge">@Model.PricePerDay.ToString("N0") đ</span></dd>
        </dl>
        <div class="d-flex flex-wrap gap-2 mt-4 pt-3 border-top">
            <a asp-action="Edit" asp-route-id="@Model.ComicBookID" class="btn btn-accent">Sửa</a>
            <a asp-action="Index" class="btn btn-outline-accent">Quay lại</a>
        </div>
    </div>
</div>
