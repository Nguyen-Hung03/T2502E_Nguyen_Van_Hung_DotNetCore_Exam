@{
    var title = ViewData["PageTitle"]?.ToString() ?? ViewData["Title"]?.ToString() ?? "";
    var subtitle = ViewData["PageSubtitle"]?.ToString();
    var actionText = ViewData["PageActionText"]?.ToString();
    var actionUrl = ViewData["PageActionUrl"]?.ToString();
    var actionController = ViewData["PageActionController"]?.ToString();
    var actionAction = ViewData["PageActionAction"]?.ToString();
}

<div class="page-header">
    <div>
        <h1 class="page-title">@title</h1>
        @if (!string.IsNullOrWhiteSpace(subtitle))
        {
            <p class="page-subtitle">@subtitle</p>
        }
    </div>
    @if (!string.IsNullOrWhiteSpace(actionText) && !string.IsNullOrWhiteSpace(actionController) && !string.IsNullOrWhiteSpace(actionAction))
    {
        <a asp-controller="@actionController" asp-action="@actionAction" asp-route-id="@ViewData["PageActionId"]" class="btn btn-accent">
            @actionText
        </a>
    }
    else if (!string.IsNullOrWhiteSpace(actionText) && !string.IsNullOrWhiteSpace(actionUrl))
    {
        <a href="@actionUrl" class="btn btn-accent">@actionText</a>
    }
</div>
