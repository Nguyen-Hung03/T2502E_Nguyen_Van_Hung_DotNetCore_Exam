@model IEnumerable<Customer>
@{
    ViewData["Title"] = "Khách hàng";
    ViewData["PageTitle"] = "Danh sách khách hàng";
    ViewData["PageSubtitle"] = $"{Model.Count()} khách hàng đã đăng ký";
    ViewData["PageActionText"] = "+ Đăng ký mới";
    ViewData["PageActionController"] = "Customers";
    ViewData["PageActionAction"] = "Register";
}

<partial name="_PageHeader" />

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-modern mb-4">@TempData["SuccessMessage"]</div>
}

<div class="panel-card">
    <div class="table-responsive">
        <table class="table table-modern">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Họ tên</th>
                    <th>Số điện thoại</th>
                    <th>Ngày đăng ký</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var index = 1;
                }
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@index</td>
                        <td class="fw-bold">@item.FullName</td>
                        <td>@item.PhoneNumber</td>
                        <td>@item.RegistrationDate.ToString("dd/MM/yyyy")</td>
                    </tr>
                    index++;
                }
            </tbody>
        </table>
    </div>
</div>
